NODE_ENV=development
PORT=5000
DATABASE_URL=postgres://postgres:password@localhost:5432/fintrack

# CORS origins are comma-separated. Example:
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN=http://localhost:5173

# Use a long random secret (at least 32 chars)
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_DAYS=30

# Optional token metadata
# JWT_ISSUER=fintrack-api
# JWT_AUDIENCE=fintrack-client

# Database connection hardening
PGSSLMODE=disable
PGSSL_REJECT_UNAUTHORIZED=true
PG_QUERY_TIMEOUT_MS=15000
PG_APP_NAME=fintrack-api
JSON_BODY_LIMIT=1mb
TRUST_PROXY=0

# OpenRouter AI reports
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
AI_REPORT_SCHEDULER=true
AI_REPORT_SCHEDULER_MODE=cron
AI_REPORT_SCHEDULER_INTERVAL_MS=5000
GOOGLE_CLIENT_ID=
PASSWORD_RESET_SECRET=replace_with_another_long_random_secret

# Optional FX table (UZS value for 1 unit of currency)
# FX_RATES_JSON={"UZS":1,"USD":12800,"EUR":13900,"RUB":145}
# Live FX API (temporary disable in local CMD by default)
FX_LIVE_ENABLED=false

# App links (for household invite email)
APP_BASE_URL=http://localhost:5173

# SMTP for invite emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
