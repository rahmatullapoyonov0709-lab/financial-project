{
  "name": "fintrack-api",
  "version": "1.0.0",
  "description": "FinTrack Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node src/scripts/runMigrations.js",
    "db:backup": "powershell -ExecutionPolicy Bypass -File ./scripts/backup.ps1",
    "db:restore": "powershell -ExecutionPolicy Bypass -File ./scripts/restore.ps1",
    "test": "node --test"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.15",
    "pg": "^8.13.0"
  }
}
