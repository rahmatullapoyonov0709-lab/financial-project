# Production Environment Template
# Bu faylni .env ga copy qilib, to'g'ri qiymatlarni kiritish kerak

# ============================================
# 🔴 JUDA MUHIM: Quyidagilarni TO'G'RIL
# ============================================

# 1. DATABASE - PRODUCTION DB URL
# GitHub, Render, yoki Supabase dan DATABASE_URL olish kerak
DATABASE_URL=postgresql://username:password@db-host.com:5432/fintrack_db

# 2. FRONTEND URL - CORS uchun
# Sizning production frontend domeni
CORS_ORIGIN=https://financial-project-1.onrender.com

APP_BASE_URL=https://financial-project-1.onrender.com

# 3. EMAIL - Gmail App Password
# Gmail: https://myaccount.google.com/apppasswords
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ============================================
# Standard Configuration
# ============================================

PORT=5000
NODE_ENV=production
JSON_BODY_LIMIT=1mb
TRUST_PROXY=1
PGSSLMODE=require

# ============================================
# JWT Security (30-40 character random string)
# ============================================
JWT_SECRET=generate-with-openssl-rand-hex-32-chars
JWT_EXPIRES_IN=7d

# ============================================
# SMTP Configuration
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM="FinTrack <your-email@gmail.com>"

# ============================================
# External Services (optional)
# ============================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# AI Scheduler
AI_REPORT_SCHEDULER=true
AI_REPORT_SCHEDULER_MODE=cron

# Optional: FX rates (currency)
FX_LIVE_ENABLED=false

# ============================================
# Database Optimization
# ============================================
PG_POOL_MAX=10
PG_QUERY_TIMEOUT_MS=15000
PG_APP_NAME=fintrack-api
